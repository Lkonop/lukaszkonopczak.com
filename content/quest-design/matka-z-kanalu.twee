(align:"<==")+(box:"=X")[HP: $health]
(if: $monster_health <= 0)[(go-to: "NODE-BOSS-DEFEATED")]

$player tnie na odlew. Końcówka srebrnego miecza rani wampira powierzchownie, mimo to, rozwściecza go.  $monster atakuje z góry.



(set: $counter to 10)
{
(live: 1s)[
	(set: $counter to it - 1)
	(if: $counter > 0)[
