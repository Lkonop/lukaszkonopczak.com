''DOSTĘPNE ELIKSIRY:'' (Masz obecnie: $money szt. złota)

<!-- ZAKUP JASKÓŁKI -->
(link: "Kup: Jaskółka (3 szt. złota)")[\
    (set: $cost to 3)\
    (if: $money >= $cost)[\
        (set: $money to $money - $cost)\
        (set: $swallow_bought to true)\
        (set: $after_purchase_dialog to true)\
        (go-to: "NODE-GO-SHOPPING")\
    ]\
    (else:)[\
        (replace: ?komunikat)[Masz za mało złota na Jaskółkę!]
    ]\
]

<!-- ZAKUP GROMU -->
 (link: "Kup: Grom (3 szt. złota)")[\
    (set: $cost to 3)\
    (if: $money >= $cost)[\
        (set: $money to $money - $cost)\
        (set: $thunderbolt_bought to true)\
        (set: $after_purchase_dialog to true)\
        (go-to: "NODE-GO-SHOPPING")\
    ]\
    (else:)[\
        (replace: ?komunikat)[Masz za mało złota na Grom!]
    ]\
]

<!-- ZAKUP CZARNEJ KRWI -->
(link: "Kup: Czarna Krew (2 szt. złota)")[\
    (set: $cost to 2)\
    (if: $money >= $cost)[\
        (set: $money to $money - $cost)\
        (set: $black_blood_elixir to "Czarna krew")\
        (set: $black_blood_bought to true)\
        (set: $after_purchase_dialog to true)\
        (go-to: "NODE-GO-SHOPPING")\
    ]\
    (else:)[\
        (replace: ?komunikat)[Masz za mało złota na Czarną Krew!]
    ]\
]

