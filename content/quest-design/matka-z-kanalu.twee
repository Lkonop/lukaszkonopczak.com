		(go-to: "NODE-BOSS-HIT-TIMER_02")
	]
]
}

(set: $dodge to 1)
(set: $block to 1)

---
(link: "Przewrót w przód")[ (stop:) (go-to: "NODE-BOSS-DODGE")]
(link: "Zablokuj atak mieczem")[ (stop:) (go-to: "NODE-BOSS-BLOCK") ]


:: NODE-BOSS-FIGHT_03 {"position":"2750,1650","size":"100,100"}
(if: $monster_health <= 0)[(go-to:"NODE-BOSS-DEFEATED")]

(if:$hurt is false)[

(link: "Zaatakuj fintą")[
(set: $monster_health to it - $attack)
(set: $hurt to true)
(go-to: "NODE-BOSS-FIGHT_03")]

$monster zamachuje się pazurami:
(link: "Unik w bok")[(set: $dodge to 2)(go-to: "NODE-BOSS-DODGE")]
(link: "Zablokuj atak mieczem")[(set: $block to 2)(go-to: "NODE-BOSS-BLOCK")]

]
(else:)[ $monster próbuje uciekać

(set: $counter to 5)
	{
	(live: 1s)[
