:: StoryScript [script]
$(document).on('keyup', function(e) {
    if (e.key === "Escape" || e.keyCode === 27) {
        // Sprawdzamy, czy nie jesteśmy już w menu, żeby uniknąć pętli
        if (typeof Engine !== 'undefined' && Engine.goTo) {
            Engine.goTo("MENU");
        } else if (typeof Harlowe !== 'undefined') {
            // Bezpieczne wywołanie przejścia dla nowszych wersji Harlowe
            var passage = "";
            $.event.trigger({type: "updatepassage", passage: passage});
        } else {
            // Uniwersalna metoda oparta na makrze Twine (symulacja kliknięcia)
            var link = document.querySelector('.go-to-menu');
            if (link) { link.click(); }
        }
    }
});

